{
  "name": "@credcli/cli",
  "version": "0.1.4",
  "description": "Mail-merge credential & certificate generator — PDF/PNG output via Playwright",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "files": [
    "dist",
    "templates"
  ],
  "bin": {
    "credcli": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "pnpm run build && node dist/cli.mjs",
    "start": "node dist/cli.mjs",
    "prepublishOnly": "pnpm run build",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "archiver": "^7.0.1",
    "chalk": "^5.3.0",
    "csv-parse": "^5.5.3",
    "csv-stringify": "^6.4.4",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs-extra": "^11.2.0",
    "ink": "^6.8.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "meow": "^14.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "open": "^11.0.0",
    "playwright": "^1.58.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "credentials",
    "certificates",
    "badges",
    "mail-merge",
    "playwright"
  ],
  "license": "MIT"
}